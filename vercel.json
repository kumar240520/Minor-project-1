{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/server.js"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}